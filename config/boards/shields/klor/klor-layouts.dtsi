#include <physical_layouts.dtsi>

/ {
    klor_physical_layout: klor_physical_layout {
        compatible = "zmk,physical-layout";
        display-name = "KLOR Layout";
        transform = <&default_transform>;

        keys  //                     w   h    x    y     rot    rx    ry
            /* Row 0: 10 keys (no outer pinky in matrix) */
            = <&key_physical_attrs 100 100  100   90 (-1000)   200   325>  /* Q */
            , <&key_physical_attrs 100 100  200   25  (-400)   275   325>  /* W */
            , <&key_physical_attrs 100 100  300    0       0     0     0>  /* E */
            , <&key_physical_attrs 100 100  400   25       0     0     0>  /* R */
            , <&key_physical_attrs 100 100  500   50       0     0     0>  /* T */
            , <&key_physical_attrs 100 100 1100   50       0     0     0>  /* Y */
            , <&key_physical_attrs 100 100 1200   25       0     0     0>  /* U */
            , <&key_physical_attrs 100 100 1300    0       0     0     0>  /* I */
            , <&key_physical_attrs 100 100 1400   25     400  1450   325>  /* O */
            , <&key_physical_attrs 100 100 1500   90    1000  1525   325>  /* P */

            /* Row 1: 12 keys (outer pinky in matrix, broken off on saegewerk) */
            , <&key_physical_attrs 100 100    0  190 (-1000)   200   325>  /* trans - left outer pinky */
            , <&key_physical_attrs 100 100  100  190 (-1000)   200   325>  /* A */
            , <&key_physical_attrs 100 100  200  125  (-400)   275   325>  /* S */
            , <&key_physical_attrs 100 100  300  100       0     0     0>  /* D */
            , <&key_physical_attrs 100 100  400  125       0     0     0>  /* F */
            , <&key_physical_attrs 100 100  500  150       0     0     0>  /* G */
            , <&key_physical_attrs 100 100 1100  150       0     0     0>  /* H */
            , <&key_physical_attrs 100 100 1200  125       0     0     0>  /* J */
            , <&key_physical_attrs 100 100 1300  100       0     0     0>  /* K */
            , <&key_physical_attrs 100 100 1400  125     400  1450   325>  /* L */
            , <&key_physical_attrs 100 100 1500  190    1000  1525   325>  /* ; */
            , <&key_physical_attrs 100 100 1600  190    1000  1525   325>  /* trans - right outer pinky */

            /* Row 2: 12 keys (outer pinky in matrix, broken off on saegewerk) */
            , <&key_physical_attrs 100 100    0  290 (-1000)   200   325>  /* trans - left outer pinky */
            , <&key_physical_attrs 100 100  100  290 (-1000)   200   325>  /* Z */
            , <&key_physical_attrs 100 100  200  225  (-400)   275   325>  /* X */
            , <&key_physical_attrs 100 100  300  200       0     0     0>  /* C */
            , <&key_physical_attrs 100 100  400  225       0     0     0>  /* V */
            , <&key_physical_attrs 100 100  500  250       0     0     0>  /* B */
            , <&key_physical_attrs 100 100 1100  250       0     0     0>  /* N */
            , <&key_physical_attrs 100 100 1200  225       0     0     0>  /* M */
            , <&key_physical_attrs 100 100 1300  200       0     0     0>  /* , */
            , <&key_physical_attrs 100 100 1400  225     400  1450   325>  /* . */
            , <&key_physical_attrs 100 100 1500  290    1000  1525   325>  /* / */
            , <&key_physical_attrs 100 100 1600  290    1000  1525   325>  /* trans - right outer pinky */

            /* Thumb row: 8 keys (4+4, outer thumbs are trans) */
            , <&key_physical_attrs 100 100  350  340       0     0     0>  /* trans - left outer thumb */
            , <&key_physical_attrs 100 100  350  340    1500   400   810>  /* LCTRL */
            , <&key_physical_attrs 100 100  350  340    3000   400   810>  /* LOWER */
            , <&key_physical_attrs 100 100  350  340    4500   400   810>  /* SPACE */

            , <&key_physical_attrs 100 100 1250  340 (-4500)  1300   810>  /* ENTER */
            , <&key_physical_attrs 100 100 1250  340 (-3000)  1300   810>  /* RAISE */
            , <&key_physical_attrs 100 100 1250  340 (-1500)  1300   810>  /* BSPC */
            , <&key_physical_attrs 100 100 1250  340       0     0     0>  /* trans - right outer thumb */
            ;
    };
};
